# ==========================================
# DATABASE CONNECTION SETTINGS (MYSQL)
# ==========================================
# Format: mysql://[user]:[password]@[host]:[port]/[database_name]
# 
# Example local (empty password):
# DATABASE_URL="mysql://root:@127.0.0.1:3306/sly_clothing"
# 
# Example remote (with password):
# DATABASE_URL="mysql://db_admin:secure_password_here@mysql-db-hostname.com:3306/sly_clothing"
DATABASE_URL="mysql://root:@127.0.0.1:3306/sly_clothing"

# ==========================================
# NESTJS SERVER SETTINGS
# ==========================================
PORT=3000
SESSION_SECRET="sly_clothing_session_secret_key_change_me"
